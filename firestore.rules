rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superAdmin';
    }
    
    function isBusinessAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'businessAdmin';
    }
    
    function isPropertyManager() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'propertyManager';
    }
    
    function hasBusinessAccess(businessId) {
      return isAuthenticated() &&
        (isSuperAdmin() ||
         (isBusinessAdmin() && exists(/databases/$(database)/documents/businessAccess/$(request.auth.uid)_$(businessId))) ||
         (isPropertyManager() && exists(/databases/$(database)/documents/properties/$(resource.data.propertyId)) && 
          get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.businessId == businessId));
    }
    
    function hasPropertyAccess(propertyId) {
      return isAuthenticated() &&
        (isSuperAdmin() ||
         (isBusinessAdmin() && get(/databases/$(database)/documents/properties/$(propertyId)).data.businessId == resource.data.businessId) ||
         (isPropertyManager() && exists(/databases/$(database)/documents/propertyAccess/$(request.auth.uid)_$(propertyId))));
    }

    // User rules
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
      allow write: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }

    // Business rules
    match /businesses/{businessId} {
      allow read: if isAuthenticated() && hasBusinessAccess(businessId);
      allow write: if isSuperAdmin();
    }

    // Property rules
    match /properties/{propertyId} {
      allow read: if isAuthenticated() && hasPropertyAccess(propertyId);
      allow write: if isSuperAdmin() || (isBusinessAdmin() && hasBusinessAccess(resource.data.businessId));
    }

    // Business access rules
    match /businessAccess/{accessId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        (accessId.split('_')[0] == request.auth.uid)
      );
      allow write: if isSuperAdmin();
    }

    // Property access rules
    match /propertyAccess/{accessId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        isBusinessAdmin() ||
        (accessId.split('_')[0] == request.auth.uid)
      );
      allow write: if isSuperAdmin() || (isBusinessAdmin() && hasBusinessAccess(resource.data.businessId));
    }

    // System-wide settings
    match /system/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }
  }
}
